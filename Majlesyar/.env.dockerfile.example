# Use this when your server/provider only builds and runs Dockerfile.
PORT=8000
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,SERVER_IP
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# SQLite persistence for Dockerfile-only deploys.
# Mount a persistent volume/disk to /data on the server.
USE_POSTGRES=0
SQLITE_DB_PATH=/data/db.sqlite3
DJANGO_MEDIA_ROOT=/data/media

# If your server provides Postgres, set USE_POSTGRES=1 and fill these instead.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
