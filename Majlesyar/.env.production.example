# Copy to .env.production on the server, then change every secret.
APP_IMAGE=majlesyar:latest
HOST_PORT=80

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,SERVER_IP
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

POSTGRES_DB=majlesyar
POSTGRES_USER=majlesyar
POSTGRES_PASSWORD=change-this-database-password

# Optional Telegram bot settings.
TELEGRAM_BOT_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USE_WEBHOOK=1
TELEGRAM_BOT_WEBHOOK_SECRET=
TELEGRAM_BOT_BASE_URL=https://your-domain.com
TELEGRAM_BOT_ALLOWED_USER_IDS=
TELEGRAM_BOT_ALLOWED_CHAT_IDS=
TELEGRAM_BOT_ADMIN_ONLY=1
TELEGRAM_BOT_NOTIFICATIONS_ENABLED=0
